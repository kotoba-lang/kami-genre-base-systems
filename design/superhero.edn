;; Genre base: スーパーヒーロー (Superhero)
{:genre/id :superhero
 :genre/status :implemented
 :genre/core-loop
 ["identical base combat loop to single-player, plus a defatom power meter
   that fills as enemies are defeated"
  "when the meter is full, player action triggers a timed \"super mode\"
   (a defatom countdown) during which weapon range/fire-rate are
   temporarily widened -- expressed purely as numeric tuning, not a new
   primitive"]
 :genre/controls {:buttons 1 :scheme ["movement + auto-attack, matching survivors' template, plus one meter-triggered mode"]}
 :genre/kami-engine
 {:proven-vocab-used [:defatom :set-atom! :count-tagged :tick-n :mod :<]
  :known-constraints
  ["\"super mode\" is expressed as swapping between two pre-defined numeric
    constant sets (normal vs. boosted range/period) gated by the countdown
    atom -- no dynamic constant mutation beyond defatom exists, so the
    boosted values are fixed, not scaled by an arbitrary formula"]}
 :games/dir "games/superhero"}
