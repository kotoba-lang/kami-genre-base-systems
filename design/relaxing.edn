;; Genre base: リラックス (Relaxing)
{:genre/id :relaxing
 :genre/status :design-only
 :genre/core-loop
 ["a \"garden\" of dormant tagged entities; touching one starts a slow
   tick-n-gated \"growth\" timer, after which it re-tags itself as
   \"grown\" (despawn+respawn with a different tag) -- entirely
   player-paced, no timers pressure the player, no fail state"]
 :genre/controls {:buttons 1 :scheme ["movement only"]}
 :genre/kami-engine
 {:proven-vocab-used [:tick-n :mod :nearest-tagged :despawn-entity :spawn-entity]
  :known-constraints
  ["closely related to kids-family's zero-fail shape but framed around a
    single slow-growth interaction loop instead of rapid collection"]}
 :games/dir "games/relaxing"}
