;; Genre base: リズム (Rhythm)
{:genre/id :rhythm
 :genre/status :implemented
 :genre/core-loop
 ["a fixed beat-period ticks continuously"
  "player action within a small window around the beat counts as a hit"
  "misses (off-beat actions) still succeed at the base rate -- reused from
   isekai-network's own design constraint: never require rhythm precision
   to progress, only reward it"]
 :genre/controls {:buttons 1 :scheme ["single action button, timing-scored"]}
 :genre/kami-engine
 {:proven-vocab-used [:defsystem :tick-n :mod :< :zero? :defatom :set-atom!
                       :spawn-entity :despawn-entity :count-tagged]
  :known-constraints
  ["directly reuses the beat? tick-gated pattern proven in
    gftdcojp/isekai-network games/01-netsurvivors/logic.clj (iteration 7 of
    that session's design-deepening work) -- no new primitive needed"]}
 :games/dir "games/rhythm"}
