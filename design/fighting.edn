;; Genre base: 対戦格闘 (Fighting)
{:genre/id :fighting
 :genre/status :design-only
 :genre/core-loop
 ["1 human + 1 AI opponent (same input-stream constraint as
   local-multiplayer), each with a defatom health counter; proximity-based
   exchanges (nearest-tagged within a fixed range) decrement the opponent's
   health on a tick-gated interval; first to zero loses, then both reset"]
 :genre/controls {:buttons 1 :scheme ["movement + auto-attack-in-range, single input stream"]}
 :genre/kami-engine
 {:proven-vocab-used [:defatom :set-atom! :nearest-tagged :get-x :get-y :tick-n :mod]
  :known-constraints
  ["same single-local-input-stream constraint as local-multiplayer.edn --
    true 2-player local fighting is not currently buildable, this is the
    1-human+1-AI honest fallback"]}
 :games/dir "games/fighting"}
