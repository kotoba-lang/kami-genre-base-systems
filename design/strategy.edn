;; Genre base: ストラテジー (Strategy)
{:genre/id :strategy
 :genre/status :implemented
 :genre/core-loop
 ["a defatom resource pool accrues automatically on a fixed tick interval
   (the \"economy\" tick)"
  "player action near a \"build\" marker spends the resource and spawns a
   new \"unit\" entity tagged for a separate ai-tick to move toward the
   nearest enemy-tagged entity"
  "units accrue, no pathfinding exists so units just walk in a straight
   line via move-toward! toward whatever is nearest"]
 :genre/controls {:buttons 1 :scheme ["movement to the build marker triggers spend/build"]}
 :genre/kami-engine
 {:proven-vocab-used [:defatom :set-atom! :tick-n :mod :spawn-entity
                        :nearest-tagged :move-toward!]
  :known-constraints
  ["no pathfinding (kami-pathfind is a Rust-substrate crate unreachable from
    kami-clj) -- units move in straight lines only, no terrain avoidance"]}
 :games/dir "games/strategy"}
