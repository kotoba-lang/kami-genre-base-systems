;; Genre base: ローカルマルチプレイヤー (Local Multiplayer)
{:genre/id :local-multiplayer
 :genre/status :design-only
 :genre/core-loop
 ["1 human + 1 AI-controlled second entity chase a shared \"ball\"/objective
   entity; whichever side's entity is nearest when a scoring condition
   fires gets the point (defatom per-side score)"]
 :genre/controls {:buttons 1 :scheme ["movement only, single input stream"]}
 :genre/kami-engine
 {:proven-vocab-used [:defatom :set-atom! :nearest-tagged :move-toward!]
  :known-constraints
  ["HARD CONSTRAINT, confirmed this session (isekai-network concept-3
    investigation, 3 independent evidence points): only ONE local input
    stream exists in the current engine -- kami-input-scene's InputMap
    schema has no player-index dimension, and no reference game's logic.clj
    calls axis with a player argument. True simultaneous local multiplayer
    is not currently buildable. This base uses 1 human + 1 AI as the only
    honest approximation, same fallback isekai-network's own concept 3
    adopted."]}
 :games/dir "games/local-multiplayer"}
