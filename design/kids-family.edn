;; Genre base: キッズ＆ファミリー (Kids & Family)
{:genre/id :kids-family
 :genre/status :design-only
 :genre/core-loop
 ["zero-fail collection loop: gentle, non-threatening entities sit
   stationary; touching one collects it (despawn + defatom counter) and a
   new one spawns elsewhere -- no timers, no chase AI, no loss condition"]
 :genre/controls {:buttons 1 :scheme ["movement only"]}
 :genre/kami-engine
 {:proven-vocab-used [:defatom :set-atom! :nearest-tagged :despawn-entity :spawn-entity]
  :known-constraints
  ["deliberately the simplest base in this repo -- no ai-tick chase system
    at all, matching a no-fail design brief"]}
 :games/dir "games/kids-family"}
