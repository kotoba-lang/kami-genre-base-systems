;; Genre base: プラットフォームゲーム (Platformer)
{:genre/id :platformer
 :genre/status :design-only
 :genre/core-loop
 ["a sequence of fixed \"platform\" tagged entities the player must reach
   IN ORDER along a single traversal axis, tracked via a defatom
   sequence-index (closest analogue to jump-across-gaps progression
   available without real physics)"]
 :genre/controls {:buttons 1 :scheme ["movement only"]}
 :genre/kami-engine
 {:proven-vocab-used [:defatom :set-atom! :nearest-tagged :get-x :get-y]
  :known-constraints
  ["NO jump/gravity primitive exists anywhere in the proven vocabulary or
    any reference game -- this is an honest limitation, not an oversight.
    This base is a sequential-waypoint traversal, not a true jump-physics
    platformer. Real platforming would need a Rust-side physics/collision
    system this repo does not have access to from kami-clj logic."]}
 :games/dir "games/platformer"}
